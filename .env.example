PORT=3009
EMAIL_GATEWAY_SERVICE_API_KEY=your-api-key
EMAIL_GATEWAY_SERVICE_DATABASE_URL=postgresql://...

POSTMARK_SERVICE_URL=http://localhost:3010
POSTMARK_SERVICE_API_KEY=your-postmark-service-key
INSTANTLY_SERVICE_URL=http://localhost:3011
INSTANTLY_SERVICE_API_KEY=your-instantly-service-key
KEY_SERVICE_URL=http://localhost:3001
KEY_SERVICE_API_KEY=your-key-service-key

# Inbound pub/sub — JSON array of subscriptions for Postmark inbound emails.
# postmark-service POSTs each inbound email to POST /inbound/postmark; this gateway
# fans it out to every subscription whose alias filter matches the recipient(s).
# Each delivery is HMAC-signed with the secret resolved from `hmac_secret_env`.
# Each subscription object:
#   name:                 logical name used in logs
#   filter.aliasPattern:  "*@inbox.example.com" (wildcard suffix) or exact "haro@inbox.example.com"
#   endpoint_url:         HTTPS URL the inbound payload is POSTed to
#   hmac_secret_env:      name of the env var holding the HMAC shared secret (resolved at boot)
# Empty/unset disables fan-out. Invalid JSON, missing fields, or missing referenced env secret → fatal exit at boot.
EMAIL_GATEWAY_SUBSCRIPTIONS=[]

# Example shared HMAC secrets referenced by EMAIL_GATEWAY_SUBSCRIPTIONS entries:
# JQS_INBOUND_HMAC_SECRET=replace-me-with-strong-random-secret
