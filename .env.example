PORT=3009
EMAIL_GATEWAY_SERVICE_API_KEY=your-api-key
EMAIL_GATEWAY_SERVICE_DATABASE_URL=postgresql://...

POSTMARK_SERVICE_URL=http://localhost:3010
POSTMARK_SERVICE_API_KEY=your-postmark-service-key
INSTANTLY_SERVICE_URL=http://localhost:3011
INSTANTLY_SERVICE_API_KEY=your-instantly-service-key
KEY_SERVICE_URL=http://localhost:3001
KEY_SERVICE_API_KEY=your-key-service-key

# Inbound forwarding rules — JSON array routing Postmark inbound webhooks to consumers.
# Each rule: { aliasPattern, consumerUrl, consumerName, consumerApiKey }.
#   aliasPattern: "*@inbox.example.com" (wildcard suffix) or exact "haro@inbox.example.com"
#   consumerUrl:  HTTPS URL the inbound payload is POSTed to
#   consumerName: logical name used in logs
#   consumerApiKey: shared service key sent as x-api-key to the consumer
# Empty/unset disables inbound forwarding. Invalid JSON or missing fields → fatal exit at boot.
INBOUND_FORWARDING_RULES=[]
